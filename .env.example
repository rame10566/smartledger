# ============================================================================
# SmartLedger Environment Variables
# ============================================================================
#
# ⚠️  ALL VALUES IN THIS FILE ARE POC DEFAULTS — NOT SECURE.
#
# 1. Copy this file:    cp .env.example .env
# 2. Generate real secrets for any *_SECRET variable:
#       python -c "import secrets; print(secrets.token_urlsafe(48))"
# 3. Replace placeholder API keys with real values
# 4. NEVER commit .env to git (it is in .gitignore)
#
# The application will refuse to start if *_SECRET values still begin
# with "change-me-" outside of test environments.
# ============================================================================

# ─── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key — used by the Agent and Semantic AI Engine
ANTHROPIC_API_KEY=sk-ant-...

# ─── Infrastructure ───────────────────────────────────────────────────────────

POSTGRES_PASSWORD=smartledger_dev
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://smartledger:smartledger_dev@localhost:5432/smartledger

# ─── Phase & Mode ─────────────────────────────────────────────────────────────

# Phase: 0 = read-only/write-guard, 1 = active writes
PHASE=1

# Write guard: true = ledger MCP rejects all writes (Phase 0)
WRITE_GUARD=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── MCP Server URLs ──────────────────────────────────────────────────────────

MCP_VALIDATION_URL=http://localhost:8001/mcp
MCP_LEDGER_URL=http://localhost:8002/mcp
MCP_SEMANTIC_AI_URL=http://localhost:8003/mcp
MCP_REPORTING_URL=http://localhost:8004/mcp

# Simulated systems
MCP_ORACLE_LOS_URL=http://localhost:8010/mcp
MCP_SALESFORCE_LOS_URL=http://localhost:8011/mcp
MCP_LLAS_URL=http://localhost:8012/mcp
MCP_CRM_URL=http://localhost:8013/mcp
MCP_PAYMENT_URL=http://localhost:8014/mcp
MCP_INSURANCE_URL=http://localhost:8015/mcp
MCP_DEALER_URL=http://localhost:8016/mcp
MCP_CUSTOMER_PORTAL_URL=http://localhost:8017/mcp
MCP_MOBILE_APP_URL=http://localhost:8018/mcp
MCP_IVR_URL=http://localhost:8019/mcp

# ─── Hyperledger Fabric (Phase 1+) ────────────────────────────────────────────
# These are set automatically in docker-compose.yml for the mcp-ledger container.
# Only needed here if running mcp-ledger outside Docker.

FABRIC_CHANNEL=smartledger-channel
FABRIC_CHAINCODE=smartledger-cc
FABRIC_MSP_ID=SmartLedgerOrgMSP

# ─── Dashboard ────────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── JWT (Phase 1 Security) ───────────────────────────────────────────────────

JWT_SECRET=change-me-in-production
JWT_EXPIRY_SECONDS=3600

# ─── Validation Proof Tokens (Validation Engine → Ledger MCP) ─────────────────
# Shared secret between Validation Engine MCP and Ledger MCP ONLY.
# Must be different from JWT_SECRET. Min 32 chars in production.

PROOF_TOKEN_SECRET=change-me-proof-token-secret
PROOF_TOKEN_EXPIRY_SECONDS=60

# ─── Dashboard JWT (Party Portal session tokens) ─────────────────────────────

DASHBOARD_JWT_SECRET=change-me-dashboard-jwt-secret

# ─── Local POC Defaults (Fabric Docker Stack) ────────────────────────────────
# These passwords are used by docker-compose for the local Fabric stack.
# Change them for any non-local deployment.

COUCHDB_PASSWORD=adminpw
FABRIC_CA_ADMIN_PASSWORD=adminpw
EXPLORER_DB_PASSWORD=password
